<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:controls="using:QQDatabaseExplorer.Controls"
              xmlns:u="https://irihi.tech/ursa"
              x:Class="QQDatabaseExplorer.Views.ImagePreviewDialog"
              Width="900"
              Height="700"
              MinWidth="360"
              MinHeight="280"
              Title="图片预览"
              Padding="0,32,0,0"
              Background="#FF202124"
              WindowStartupLocation="CenterOwner">

    <u:UrsaWindow.Resources>
        <SolidColorBrush x:Key="CaptionButtonForeground" Color="White" />
    </u:UrsaWindow.Resources>

    <controls:ZoomableLocalImageViewer
        Name="PreviewImageViewer"
        Background="#FF202124" />
</u:UrsaWindow>
