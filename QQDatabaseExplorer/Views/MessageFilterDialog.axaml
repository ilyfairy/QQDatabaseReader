<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:QQDatabaseExplorer.ViewModels"
        xmlns:models="using:QQDatabaseExplorer.Models"
        xmlns:controls="using:QQDatabaseExplorer.Controls"
        xmlns:primitives="using:Avalonia.Controls.Primitives"
        mc:Ignorable="d"
        SizeToContent="Height"
        MinHeight="0"
        Classes.GroupMode="{Binding IsGroupConversation}"
        x:Class="QQDatabaseExplorer.Views.MessageFilterDialog"
        Title="筛选条件"
        x:DataType="vm:MessageFilterDialogViewModel"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Width" Value="382" />
            <Setter Property="MinWidth" Value="332" />
        </Style>
        <Style Selector="Window.GroupMode">
            <Setter Property="Width" Value="720" />
            <Setter Property="MinWidth" Value="640" />
        </Style>
        <Style Selector="Button.CalendarDayButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.CalendarDayButton.Available /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.CalendarDayButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E8F1FF" />
            <Setter Property="BorderBrush" Value="#9EC5FF" />
        </Style>
        <Style Selector="Button.CalendarDayButton.Selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#F2F7FF" />
            <Setter Property="BorderBrush" Value="#9EC5FF" />
        </Style>
        <Style Selector="Button.CalendarDayButton.Selected TextBlock.DayNumber">
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="Button.CalendarDayButton.Selected TextBlock.DayCount">
            <Setter Property="Foreground" Value="#1677FF" />
        </Style>
        <Style Selector="Button.CalendarDayButton.Empty">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Button.CalendarDayButton.DisabledDay">
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Button.MonthNavButton">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#F4F6FA" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Grid.FilterContentGrid">
            <Setter Property="Width" Value="300" />
            <Setter Property="ColumnSpacing" Value="0" />
        </Style>
        <Style Selector="Grid.FilterContentGrid.GroupMode">
            <Setter Property="Width" Value="652" />
            <Setter Property="ColumnSpacing" Value="22" />
        </Style>
        <Style Selector="Border.DateCard">
            <Setter Property="Width" Value="300" />
        </Style>
    </Window.Styles>

    <Border Padding="20,20,20,10">
        <Grid RowDefinitions="Auto Auto">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical" Spacing="20">
                    <Grid
                        Classes="FilterContentGrid"
                        Classes.GroupMode="{Binding IsGroupConversation}"
                        HorizontalAlignment="Center"
                        ColumnDefinitions="Auto *">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock
                                FontSize="14"
                                Foreground="#555"
                                Text="发送日期" />

                            <Border
                                Classes="DateCard"
                                HorizontalAlignment="Center"
                                Padding="8"
                                Background="#FFFDFDFE"
                                BorderBrush="#16000000"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="32 * 32">
                                        <Button
                                            Grid.Column="0"
                                            Classes="MonthNavButton"
                                            Command="{Binding ShowPreviousMonthCommand}"
                                            Content="‹"
                                            FontSize="22"
                                            IsEnabled="{Binding CanShowPreviousMonth}"
                                            ToolTip.Tip="上个月" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="19"
                                            FontWeight="SemiBold"
                                            Text="{Binding VisibleMonthText}" />
                                        <Button
                                            Grid.Column="2"
                                            Classes="MonthNavButton"
                                            Command="{Binding ShowNextMonthCommand}"
                                            Content="›"
                                            FontSize="22"
                                            IsEnabled="{Binding CanShowNextMonth}"
                                            ToolTip.Tip="下个月" />
                                    </Grid>

                                    <Grid
                                        Width="252"
                                        HorizontalAlignment="Center"
                                        ColumnDefinitions="36 36 36 36 36 36 36">
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="一" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="二" />
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="三" />
                                        <TextBlock Grid.Column="3" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="四" />
                                        <TextBlock Grid.Column="4" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="五" />
                                        <TextBlock Grid.Column="5" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="六" />
                                        <TextBlock Grid.Column="6" HorizontalAlignment="Center" FontSize="12" Foreground="#667085" Text="日" />
                                    </Grid>

                                    <ItemsControl
                                        Width="252"
                                        HorizontalAlignment="Center"
                                        ItemsSource="{Binding DateCells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <primitives:UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.DataTemplates>
                                            <DataTemplate DataType="models:MessageDateFilterCell">
                                                <Button
                                                    Classes="CalendarDayButton"
                                                    Classes.Empty="{Binding IsEmpty}"
                                                    Classes.DisabledDay="{Binding IsDisabled}"
                                                    Classes.Available="{Binding HasMessages}"
                                                    Classes.Selected="{Binding IsSelected}"
                                                    Command="{Binding $parent[Window].DataContext.ToggleDateCommand}"
                                                    CommandParameter="{Binding}">
                                                    <StackPanel Spacing="0">
                                                        <TextBlock
                                                            Classes="DayNumber"
                                                            HorizontalAlignment="Center"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="#222"
                                                            Text="{Binding DayText}" />
                                                        <TextBlock
                                                            Classes="DayCount"
                                                            HorizontalAlignment="Center"
                                                            FontSize="9"
                                                            Foreground="#1677FF"
                                                            IsVisible="{Binding HasMessages}"
                                                            Text="{Binding MessageCountText}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.DataTemplates>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>
                        </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="8"
                        IsVisible="{Binding IsGroupConversation}">
                        <TextBlock
                            FontSize="14"
                            Foreground="#555"
                            Text="发送人" />

                        <TextBox
                            Text="{Binding SenderSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="搜索昵称、QQ号或 nt_uid" />

                        <Grid ColumnDefinitions="* Auto" ColumnSpacing="8">
                            <TextBox
                                Grid.Column="0"
                                Text="{Binding SenderIdInput, Mode=TwoWay}"
                                PlaceholderText="手动输入多个 QQ号，用空格或逗号分隔" />
                            <Button
                                Grid.Column="1"
                                Padding="12,4"
                                Command="{Binding AddManualSendersCommand}"
                                Content="添加" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding SelectedSenders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.DataTemplates>
                                <DataTemplate DataType="models:MessageSenderFilterOption">
                                    <Border
                                        Margin="0,0,6,6"
                                        Padding="8,4"
                                        Background="#FFE8F1FF"
                                        BorderBrush="#221677FF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock
                                                MaxWidth="220"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="{Binding DisplayText}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Button
                                                MinWidth="0"
                                                Padding="4,0"
                                                Command="{Binding $parent[Window].DataContext.RemoveSenderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="×" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>

                        <Border
                            MinHeight="180"
                            Padding="8"
                            Background="#06FFFFFF"
                            BorderBrush="#16000000"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ListBox
                                MaxHeight="240"
                                ItemsSource="{Binding SenderCandidates}"
                                SelectionMode="Single"
                                DoubleTapped="SenderCandidateList_DoubleTapped">
                                <ListBox.DataTemplates>
                                    <DataTemplate DataType="models:MessageSenderFilterOption">
                                        <Grid
                                            MinHeight="36"
                                            ColumnDefinitions="28 *"
                                            ColumnSpacing="8"
                                            DoubleTapped="SenderCandidateItem_DoubleTapped">
                                            <Border
                                                Width="28"
                                                Height="28"
                                                VerticalAlignment="Center"
                                                Background="#FFE8EAF0"
                                                CornerRadius="14" />
                                            <controls:AvatarImage
                                                Width="28"
                                                Height="28"
                                                VerticalAlignment="Center"
                                                SourceUrl="{Binding AvatarUrl}"
                                                Stretch="UniformToFill" />
                                            <StackPanel
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="1">
                                                <TextBlock
                                                    FontSize="13"
                                                    Text="{Binding DisplayName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="#777"
                                                    Text="{Binding SenderId}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.DataTemplates>
                            </ListBox>
                        </Border>
                    </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <Button
                    DockPanel.Dock="Left"
                    Padding="12,5"
                    Command="{Binding ClearAllCommand}"
                    Content="清空" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button
                        MinWidth="72"
                        Padding="12,5"
                        Command="{Binding ApplyCommand}"
                        Content="确定" />
                    <Button
                        MinWidth="72"
                        Padding="12,5"
                        Command="{Binding CancelCommand}"
                        Content="取消" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
